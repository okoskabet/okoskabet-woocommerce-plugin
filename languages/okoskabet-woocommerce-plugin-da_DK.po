# Settings page — sections that are visible alongside the merchant UI
msgid "Master switches that apply across all merchants."
msgstr "Master-switches der gælder på tværs af alle merchants."

msgid "Webhook and payment settings."
msgstr "Webhook- og betalingsindstillinger."

msgid "Enable or disable webhook functionality (applies to ALL merchants)."
msgstr "Slå webhook-funktionalitet til eller fra (gælder ALLE merchants)."

msgid "Enable or disable webhook functionality."
msgstr "Slå webhook-funktionalitet til eller fra."

msgid "Legacy Webhook URL"
msgstr "Legacy webhook URL"

msgid "Legacy URL — still works and routes to the default merchant. Each merchant has its own dedicated webhook URL listed under \"Økoskabet merchants\" below, which we recommend you configure at Økoskabet instead."
msgstr "Legacy URL — virker stadig og ruteres til standard-merchanten. Hver merchant har sin egen dedikerede webhook URL angivet under \"Økoskabet-merchants\" nedenfor, som vi anbefaler du i stedet konfigurerer hos Økoskabet."

msgid "Choose which events from Økoskabet should capture the payment."
msgstr "Vælg hvilke events fra Økoskabet der skal udløse capture af betalingen."

msgid "Choose which events from Økoskabet should mark the order as completed."
msgstr "Vælg hvilke events fra Økoskabet der skal markere ordren som fuldført."

