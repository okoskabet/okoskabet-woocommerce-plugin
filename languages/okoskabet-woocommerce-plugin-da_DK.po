msgid "Økoskabet routing"
msgstr "Økoskabet-routing"

msgid "Use Økoskabet merchant"
msgstr "Brug Økoskabet-merchant"

msgid "Auto (use category/tag rules)"
msgstr "Auto (brug kategori-/tag-regler)"

