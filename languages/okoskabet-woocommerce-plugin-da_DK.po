# Merchants admin — Add/Edit form
msgid "Edit merchant"
msgstr "Rediger merchant"

msgid "Display name"
msgstr "Visningsnavn"

msgid "A human-readable name shown only inside this admin. Customers never see it directly."
msgstr "Et menneskeligt læseligt navn der kun vises herinde i admin. Kunderne ser det aldrig direkte."

msgid "Identifier (slug)"
msgstr "Identifikator (slug)"

msgid "Lowercase letters, digits, dashes and underscores. Appears in the webhook URL — choose carefully because changing it later breaks any webhook URL already configured at Økoskabet."
msgstr "Små bogstaver, cifre, bindestreger og underscores. Optræder i webhook URL'en — vælg omhyggeligt, da en senere ændring bryder en allerede konfigureret webhook URL hos Økoskabet."

msgid "API key"
