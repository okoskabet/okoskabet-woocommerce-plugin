msgid "Økoskabet ID"
msgstr "Økoskabet ID"

msgid "Økoskabet Delivery Date"
msgstr "Økoskabet Leveringsdato"

msgid "Delivery location"
msgstr "Leveringssted"

msgid "Note to the driver (optional)"
msgstr "Besked til chaufføren (valgfrit)"

msgid "Økoskabet Delivery location"
msgstr "Økoskabet Leveringssted"

msgid "Note to driver"
msgstr "Besked til chauffør"

msgid "Chilled pickup location where you can collect your goods around the clock using a code."
msgstr "Afkølet afhentningssted hvor du kan hente dine varer hele døgnet vha. kode."

msgid "Økoskabet delivers your goods to your door."
msgstr "Økoskabet leverer dine varer til døren."

msgid "Delivery to Økoskabet"
msgstr "Levering til Økoskabet"

msgid "Please select an Økoskab and Delivery date before submitting the order."
msgstr "Vælg venligst et Økoskab og en leveringsdato før du afsender ordren."

msgid "You can remove one or more of the marked items from your cart to get more delivery options, or contact us for help."
msgstr "Du kan fjerne en eller flere af de markerede varer fra kurven for at få flere leveringsmuligheder, eller kontakte os for hjælp."

# Split-checkout strings (1.3.0)
msgid "Allow split checkout"
msgstr "Tillad opdelt checkout"

msgid "When ON: if a customer's cart contains items that cannot all be delivered on the same day, they'll be guided through one separate order per delivery date. When OFF: a notice tells the customer to remove items so they all share at least one delivery date."
msgstr "Når TÆNDT: hvis en kundes kurv indeholder varer der ikke alle kan leveres samme dag, guides kunden gennem én separat ordre per leveringsdato. Når SLUKKET: en besked beder kunden fjerne varer så de har mindst én fælles leveringsdato."

msgid "Your items must be delivered on %d separate day"
msgid_plural "Your items must be delivered on %d separate days"
msgstr[0] "Dine varer skal leveres på %d separat dag"
msgstr[1] "Dine varer skal leveres på %d separate dage"

msgid "You'll need to complete one order per delivery day. We'll guide you through each step."
msgstr "Du skal gennemføre én ordre per leveringsdag. Vi guider dig gennem hvert trin."

msgid "Delivery %1$d (%2$s)"
msgstr "Levering %1$d (%2$s)"

msgid "I understand I will complete %d separate order"
msgid_plural "I understand I will complete %d separate orders"
msgstr[0] "Jeg forstår at jeg skal gennemføre %d separat ordre"
msgstr[1] "Jeg forstår at jeg skal gennemføre %d separate ordrer"

msgid "Continue with delivery %1$d of %2$d"
msgstr "Fortsæt med levering %1$d af %2$d"

msgid "Please acknowledge the split first."
msgstr "Bekræft venligst opdelingen først."

msgid "Working…"
msgstr "Arbejder…"

msgid "Could not start split checkout. Please try again."
msgstr "Kunne ikke starte opdelt checkout. Prøv venligst igen."

msgid "You're ordering delivery %1$d of %2$d"
msgstr "Du bestiller levering %1$d af %2$d"

msgid "After you complete this order, we'll guide you to the next delivery."
msgstr "Når du har gennemført denne ordre, guider vi dig videre til næste levering."

msgid "Your cart contains items requiring multiple deliveries. Please use the split-checkout flow shown above."
msgstr "Din kurv indeholder varer der kræver flere leveringer. Brug venligst opdelt checkout-flowet vist ovenfor."

msgid "All deliveries booked!"
msgstr "Alle leveringer er bestilt!"

msgid "You've completed all the orders for your split delivery."
msgstr "Du har gennemført alle ordrer for din opdelte levering."

msgid "You have more deliveries to book"
msgstr "Du har flere leveringer at bestille"

msgid "Thanks for your order. You still need to book delivery %1$d of %2$d."
msgstr "Tak for din ordre. Du skal stadig bestille levering %1$d af %2$d."

msgid "Next: %s"
msgstr "Næste: %s"

msgid "Book next delivery now"
msgstr "Bestil næste levering nu"

msgid "Could not resume split checkout. Please add the items to your cart manually."
msgstr "Kunne ikke genoptage opdelt checkout. Tilføj venligst varerne til kurven manuelt."

msgid "Could not resume split checkout."
msgstr "Kunne ikke genoptage opdelt checkout."

# 1.3.4
msgid "Please tick the box above first."
msgstr "Sæt venligst flueben i feltet ovenfor først."

# 1.3.5 — thank-you banner improvements
msgid "Step %1$d of %2$d completed"
msgstr "Trin %1$d af %2$d gennemført"

msgid "Next: delivery %d"
msgstr "Næste: levering %d"

msgid "You can also scroll down to see your order confirmation first."
msgstr "Du kan også scrolle ned for at se din ordrebekræftelse først."
